# ─── Server ──────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Security ────────────────────────────────
# JWT_SECRET: مفتاح عشوائي طويل (min 32 حرف) — مثال: openssl rand -hex 32
JWT_SECRET=ضع-مفتاح-سري-طويل-هنا-min-32-chars
JWT_EXPIRES=7d

# ADMIN_PASSWORD: كلمة سر الأدمين للدخول برقم admin
ADMIN_PASSWORD=ضع-كلمة-سر-الأدمين

# ALLOWED_ORIGINS: رابط تطبيقك على Render — مع فاصلة إذا أكثر من رابط
# مثال: https://wassalni-backend.onrender.com
ALLOWED_ORIGINS=https://wassalni-backend.onrender.com

# ─── Firebase Admin SDK ───────────────────────
# جميع هذه البيانات من ملف serviceAccountKey.json في Firebase Console
# Project Settings → Service Accounts → Generate New Private Key
FIREBASE_PROJECT_ID=wassalni--app
FIREBASE_DATABASE_URL=https://wassalni--app-default-rtdb.firebaseio.com
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
# مهم جداً: أضف "علامات الاقتباس" حول المفتاح في Render
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXX\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@wassalni--app.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
